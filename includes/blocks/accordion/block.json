{
  "apiVersion": 3,
  "name": "ert-content-tools/accordion",
  "title": "ERT Accordion",
  "category": "widgets",
  "icon": "menu",
  "textdomain": "ert-content-tools",
  "description": "Accordion block",
  "keywords": ["accordion", "toggle", "collapse"],
  "supports": {
    "html": true,
    "className": true,
    "customClassName": true,
    "anchor": true,
    "reusable": true,
    "align": ["wide", "full"],

    "color": {
      "background": true,
      "text": true,
      "link": true,
      "gradients": true
    },

    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontFamily": true,
      "fontStyle": true,
      "fontWeight": true,
      "textDecoration": true,
      "textTransform": true,
      "letterSpacing": true
    },

    "spacing": {
      "margin": true,
      "padding": true
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "shadow": true
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [
        { "title": "Accordion Item 1", "content": "Content for item 1" },
        { "title": "Accordion Item 2", "content": "Content for item 2" }
      ]
    },
    "className": { "type": "string", "default": "" },
    "style": {
      "spacing": {},
      "border": {},
      "typography": {},
      "color": {},
      "shadow": {}
    }
  },
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css"
}
