{
  "apiVersion": 3,
  "name": "ert-content-tools/note",
  "title": "ERT Note",
  "category": "widgets",
  "icon": "sticky",
  "supports": {
    "html": true,
    "className": true,
    "customClassName": true,
    "anchor": true,
    "reusable": true,
    "align": ["wide", "full"],

    "color": {
      "background": false,
      "text": true,
      "link": true,
      "gradients": false
    },

    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontFamily": true,
      "fontStyle": true,
      "fontWeight": true,
      "textDecoration": true,
      "textTransform": true,
      "letterSpacing": true
    },

    "spacing": {
      "margin": true,
      "padding": true
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "shadow": false
  },
  "attributes": {
    "corner": { "type": "string", "default": "top-right" },
    "paperColor": { "type": "string", "default": "#fff8b0" },
    "noteWidthMode": { "type": "string", "default": "fixed" },
    "noteWidth": { "type": "number", "default": 320 },
    "noteWidthUnit": { "type": "string", "default": "px" },
    "noteAlign": { "type": "string", "default": "left" },
    "noteTextAlign": { "type": "string", "default": "left" },
    "outerShadow": { "type": "string", "default": "soft" },
    "foldShadow": { "type": "string", "default": "soft" },
    "noteFont": { "type": "string", "default": "default" },
    "text": { "type": "string", "default": "" },
    "pinColor": { "type": "string", "default": "#ff0000" },
    "style": {
      "type": "object",
      "default": {},
      "properties": {
        "color": {
          "type": "object",
          "default": {}
        },
        "spacing": {
          "type": "object",
          "default": {}
        },
        "border": {
          "type": "object",
          "default": {}
        },
        "typography": {
          "type": "object",
          "default": {}
        },
        "shadow": {
          "type": "string",
          "default": ""
        }
      }
    }
  },
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css"
}
